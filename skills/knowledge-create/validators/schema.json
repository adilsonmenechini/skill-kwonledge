{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Knowledge Note Metadata Schema",
  "description": "Schema for validating knowledge note frontmatter",
  "type": "object",
  "required": ["id", "type", "domain", "tags", "summary"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier (domain.type.slug)",
      "pattern": "^[a-z0-9-]+\\.[a-z0-9-]+\\.[a-z0-9-]+$",
      "examples": ["sre.runbook.incident-response", "kubernetes.pattern.service-mesh"]
    },
    "type": {
      "type": "string",
      "enum": ["concept", "pattern", "runbook", "architecture"],
      "description": "Knowledge type"
    },
    "domain": {
      "type": "string",
      "description": "Knowledge domain/category",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "description": "Human-readable title"
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "description": "Topic tags for filtering"
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "Brief 1-2 sentence summary"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Alternative names"
    },
    "related": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+\\.[a-z0-9-]+\\.[a-z0-9-]+$"
      },
      "description": "IDs of related knowledge"
    },
    "source": {
      "type": "string",
      "format": "uri",
      "description": "Source documentation URL"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "deprecated"],
      "default": "active"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "default": "1.0.0"
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "default": "medium"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp"
    },
    "quality_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Quality score (0-100)"
    }
  }
}